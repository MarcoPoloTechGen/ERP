# Copier ce fichier en .env pour le développement local
# et configurer les variables dans Supabase Dashboard pour la production

# API Key pour Resend (service d'envoi d'emails)
# Obtenez une clé gratuite sur https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email d'expédition
FROM_EMAIL=noreply@btp-erp.com

# URL Supabase (auto-configuré par Supabase)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
